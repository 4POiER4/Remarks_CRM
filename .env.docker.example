# Copy this file to .env before docker compose up.

APP_PORT=8080

POSTGRES_PASSWORD=zamechaniya_test_password
JWT_SECRET=change-this-secret-for-testing
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
WEB_CONCURRENCY=1
MAX_UPLOAD_SIZE_MB=1024
ALLOWED_UPLOAD_EXTENSIONS=.doc,.docx,.xls,.xlsx,.xlsm,.pdf,.jpg,.jpeg,.png,.txt

LDAP_ENABLED=false

# Set true for a ready-to-test demo database with local users.
SEED_TEST_USERS=true
TEST_USER_PASSWORD=test123

# Default admin user for local auth.
DEV_ADMIN_USERNAME=admin
DEV_ADMIN_PASSWORD=admin
