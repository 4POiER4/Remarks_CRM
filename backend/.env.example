APP_ENV=development

# SQLite для локальной разработки, PostgreSQL для production (docker-compose)
DATABASE_URL=sqlite:///./zamechaniya.db
# DATABASE_URL=postgresql+psycopg://zamechaniya:zamechaniya_secret@localhost:5432/zamechaniya

REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=60

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=1800

DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=200
WEB_CONCURRENCY=4

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

LDAP_ENABLED=false
LDAP_SERVER=ldap://dc.company.local
LDAP_BASE_DN=DC=company,DC=local
LDAP_BIND_DN=CN=svc-zamechaniya,OU=Service Accounts,DC=company,DC=local
LDAP_BIND_PASSWORD=
LDAP_USER_FILTER=(&(objectClass=user)(sAMAccountName={username}))
LDAP_GROUP_GIP=CN=GIP-Users,OU=Groups,DC=company,DC=local
LDAP_GROUP_DEPARTMENT_HEAD=CN=Dept-Heads,OU=Groups,DC=company,DC=local
LDAP_GROUP_ADMIN=CN=Admins,OU=Groups,DC=company,DC=local

JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=480
DEV_ADMIN_USERNAME=admin
DEV_ADMIN_PASSWORD=admin
